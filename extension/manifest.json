{
  "manifest_version": 3,
  "name": "Ragnarok",
  "version": "1.0",
  "description": "programa para organizar las contraseñas",
  "icons": {
  	"48":"icon.png","96":"icon.png","128":"icon.png"
  },
  "action": {
    "default_popup": "htmls/popup.html"
  },
  "options_ui": {
    "page": "htmls/password-popup.html",
    "open_in_tab": false
  },
  "background": {
    "scripts": ["htmls/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["htmls/content.js"]
    }
  ],
  "permissions": ["tabs", "storage", "notifications", "webRequest", "windows"],
  "host_permissions": ["<all_urls>"]
}
